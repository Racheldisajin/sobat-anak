APP_NAME=SobatAnak
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_LOCALE=id
APP_FALLBACK_LOCALE=en
LOG_CHANNEL=stack
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sobatanak_db
DB_USERNAME=root
DB_PASSWORD=
CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
# Gemini API untuk AI Chat SobatAnak
# Ambil API key dari Google AI Studio, lalu isi di .env
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
